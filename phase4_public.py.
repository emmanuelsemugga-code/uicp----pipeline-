#!/usr/bin/env python3
"""
phase4_public.py – Public Phase 4 interface.
Imports the internal enforcement gateway and exposes only the validated
runtime contract. No internal algorithms are revealed.
"""
import sys
import json

import phase4_engine as _engine


class PublicEnforcementGateway:
    """Public wrapper around the Phase 4 enforcement engine."""

    def __init__(self):
        self._gw = _engine.Phase4EnforcementGateway()

    def load_phase3_contract(self, contract: dict) -> None:
        """Accept a frozen Phase 3 output contract. Raises RuntimeError if status != "OK"."""
        self._gw.load_phase3_contract(contract)

    def check_output(self, request: dict) -> dict:
        """
        Evaluate a model output against the loaded constraint set.
        request: {"bindings": {"x":5, "y":10}, "output_id": "..."}
        Returns the full decision contract.
        """
        return self._gw.check_output(request)

    @staticmethod
    def sanitise_for_model(decision: dict) -> dict:
        """Strip all constraint internals before returning to the model."""
        return _engine.Phase4EnforcementGateway.sanitise_for_model(decision)

    def get_decision_log(self) -> list[dict]:
        """Return a read‑only copy of the immutable decision log."""
        return self._gw.get_decision_log()

    def verify_chain_integrity(self) -> bool:
        """Verify that no log entry has been tampered with."""
        return self._gw.verify_chain_integrity()

    def get_review_queue(self) -> list[dict]:
        """Return all NONLINEAR and OUT_OF_SCOPE constraints pending manual review."""
        return self._gw.get_review_queue()
