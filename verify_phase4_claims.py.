#!/usr/bin/env python3
"""
verify_phase4_claims.py – External Adversarial Phase 4 Verification
Uses the PUBLIC phase4_public interface ONLY.
No internal algorithms are exposed.
"""
import json
import hashlib
from phase4_public import PublicEnforcementGateway

PASS, FAIL = 0, 0

def test(name, condition, detail=""):
    global PASS, FAIL
    if condition:
        PASS += 1
        print(f"[PASS] {name}")
    else:
        FAIL += 1
        print(f"[FAIL] {name}  —  {detail}")
    if detail and condition:
        print(f"       {detail}")

print("=" * 70)
print("PHASE 4 — EXTERNAL ADVERSARIAL VALIDATION SUITE")
print("=" * 70)

# ------------------------------------------------------------------
# CLAIM 1 — CONTRACT INTEGRITY
# ------------------------------------------------------------------
print("\n--- CLAIM 1: CONTRACT INTEGRITY ---")
for bad_status in ["PARTIAL", "FAIL", None]:
    try:
        gw = PublicEnforcementGateway()
        gw.load_phase3_contract({"status": bad_status, "canonical_constraints": []})
        test(f"Rejects status != OK ({bad_status})", False, "Should have raised RuntimeError")
    except RuntimeError:
        test(f"Rejects status != OK ({bad_status})", True)
try:
    gw = PublicEnforcementGateway()
    gw.load_phase3_contract({
        "status": "OK",
        "canonical_constraints": [
            {"identity_string": "C1", "canonical_form": "x >= 6",
             "classification": "LINEAR_SINGLE_VAR", "derived_from": [], "reason": ""}
        ]
    })
    test("Accepts valid contract with status=OK", True)
except Exception as e:
    test("Accepts valid contract with status=OK", False, str(e))

# ------------------------------------------------------------------
# CLAIM 2 — BINDING VALIDATION
# ------------------------------------------------------------------
print("\n--- CLAIM 2: BINDING VALIDATION ---")
def fresh_gw():
    gw = PublicEnforcementGateway()
    gw.load_phase3_contract({
        "status": "OK",
        "canonical_constraints": [
            {"identity_string": "C1", "canonical_form": "x >= 6",
             "classification": "LINEAR_SINGLE_VAR", "derived_from": [], "reason": ""}
        ]
    })
    return gw

d = fresh_gw().check_output({"bindings": {"x": 3.14}, "output_id": "FLOAT"})
test("Float binding → BLOCK", d["status"] == "BLOCK")
d = fresh_gw().check_output({"bindings": {"x": True}, "output_id": "BOOL"})
test("Boolean binding → BLOCK", d["status"] == "BLOCK")
d = fresh_gw().check_output({"bindings": {"x": "six"}, "output_id": "STR"})
test("String value binding → BLOCK", d["status"] == "BLOCK")
d = fresh_gw().check_output({"bindings": {1: 6}, "output_id": "INTKEY"})
test("Integer key in bindings → BLOCK", d["status"] == "BLOCK")
d = fresh_gw().check_output({"bindings": {"x": 2**127}, "output_id": "OVERFLOW"})
test("Out-of-128-bit-range binding → BLOCK", d["status"] == "BLOCK")
d = fresh_gw().check_output({"bindings": {"x": -1}, "output_id": "NEG"})
test("Negative int binding valid (constraint-level BLOCK)", d["status"] == "BLOCK")

# ------------------------------------------------------------------
# CLAIM 3 — ENFORCEABLE CONSTRAINT CHECKING
# ------------------------------------------------------------------
print("\n--- CLAIM 3: ENFORCEABLE CONSTRAINT CHECKING ---")
MULTI_CONTRACT = {
    "status": "OK",
    "canonical_constraints": [
        {"identity_string": "C_001", "canonical_form": "x >= 6",
         "classification": "LINEAR_SINGLE_VAR", "derived_from": [], "reason": ""},
        {"identity_string": "C_002", "canonical_form": "x + 2*y <= 20",
         "classification": "LINEAR_MULTI_VAR", "derived_from": [], "reason": ""},
    ]
}
gw3 = PublicEnforcementGateway()
gw3.load_phase3_contract(MULTI_CONTRACT)

d = gw3.check_output({"bindings": {"x": 6, "y": 5}, "output_id": "ALLOW"})
test("ALLOW when all constraints satisfied", d["status"] == "ALLOW" and len(d["violations"]) == 0)
d = gw3.check_output({"bindings": {"x": 5, "y": 5}, "output_id": "BLOCK-C1"})
test("BLOCK when C_001 violated", d["status"] == "BLOCK" and any(v["constraint_identity"] == "C_001" for v in d["violations"]))
d = gw3.check_output({"bindings": {"x": 7, "y": 8}, "output_id": "BLOCK-C2"})
test("BLOCK when C_002 violated", d["status"] == "BLOCK" and any(v["constraint_identity"] == "C_002" for v in d["violations"]))
d = gw3.check_output({"bindings": {"x": 4, "y": 9}, "output_id": "BLOCK-BOTH"})
test("BLOCK and report both violations", d["status"] == "BLOCK" and len(d["violations"]) == 2)

# ------------------------------------------------------------------
# CLAIM 4 — NON-ENFORCEABLE DO NOT BLOCK
# ------------------------------------------------------------------
print("\n--- CLAIM 4: NON-ENFORCEABLE CONSTRAINTS — NO AUTO-BLOCK ---")
REVIEW_CONTRACT = {
    "status": "OK",
    "canonical_constraints": [
        {"identity_string": "C_LINEAR", "canonical_form": "x >= 1",
         "classification": "LINEAR_SINGLE_VAR", "derived_from": [], "reason": ""},
        {"identity_string": "C_NONLINEAR", "canonical_form": "x^2 >= 4",
         "classification": "NONLINEAR", "derived_from": [], "reason": "Nonlinear"},
        {"identity_string": "C_OOS", "canonical_form": "temporal",
         "classification": "OUT_OF_SCOPE", "derived_from": [], "reason": "Out of scope"},
    ]
}
gw4 = PublicEnforcementGateway()
gw4.load_phase3_contract(REVIEW_CONTRACT)
d = gw4.check_output({"bindings": {"x": 2}, "output_id": "REVIEW"})
test("NONLINEAR + OUT_OF_SCOPE do not cause BLOCK", d["status"] == "ALLOW")
test("Review queue populated", len(gw4.get_review_queue()) == 2)

# ------------------------------------------------------------------
# CLAIM 5 — IDENTITY IMMUTABILITY
# ------------------------------------------------------------------
print("\n--- CLAIM 5: IDENTITY IMMUTABILITY ---")
d = gw3.check_output({"bindings": {"x": 5, "y": 5}, "output_id": "IDENTITY"})
for v in d["violations"]:
    test(f"Identity string unmodified: {v['constraint_identity']!r}",
         v["constraint_identity"] in {"C_001", "C_002"})

# ------------------------------------------------------------------
# CLAIM 6 — DETERMINISM
# ------------------------------------------------------------------
print("\n--- CLAIM 6: DETERMINISM ---")
sample = {"status": "ALLOW", "violations": [], "output_id": "DET", "timestamp": "2024-01-01T00:00:00+00:00"}
canonical = json.dumps(sample, sort_keys=True, separators=(",", ":"))
r1 = hashlib.sha256(canonical.encode("utf-8")).hexdigest()
r2 = hashlib.sha256(canonical.encode("utf-8")).hexdigest()
test("SHA256(same record) identical", r1 == r2)

gw6 = fresh_gw()
d_det = gw6.check_output({"bindings": {"x": 7}, "output_id": "DET-ENG"})
recomputed = hashlib.sha256(json.dumps({
    "status": d_det["status"], "violations": d_det["violations"],
    "output_id": d_det["output_id"], "timestamp": d_det["timestamp"]
}, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()
test("Engine decision_id matches external recomputation", d_det["decision_id"] == recomputed)

d_other = fresh_gw().check_output({"bindings": {"x": 5}, "output_id": "DET-DIFF"})
test("Different bindings → different decision_id", d_det["decision_id"] != d_other["decision_id"])

# ------------------------------------------------------------------
# CLAIM 7 — CRYPTOGRAPHIC CHAIN INTEGRITY
# ------------------------------------------------------------------
print("\n--- CLAIM 7: CRYPTOGRAPHIC CHAIN INTEGRITY ---")
gw7 = fresh_gw()
for i in range(5):
    gw7.check_output({"bindings": {"x": 6 + i}, "output_id": f"CHAIN-{i}"})
test("Chain integrity after 5 decisions", gw7.verify_chain_integrity())

# ------------------------------------------------------------------
# CLAIM 8 — SANITISED MODEL-FACING RESPONSE
# ------------------------------------------------------------------
print("\n--- CLAIM 8: SANITISED MODEL-FACING RESPONSE ---")
gw8 = PublicEnforcementGateway()
gw8.load_phase3_contract(MULTI_CONTRACT)
d_block = gw8.check_output({"bindings": {"x": 4, "y": 3}, "output_id": "SAN"})
sanitised = PublicEnforcementGateway.sanitise_for_model(d_block)
test("Sanitised response has only allowed keys",
     set(sanitised.keys()) == {"status", "sanitised_reason", "output_id", "decision_id"})
has_leak = any(fragment in sanitised.get("sanitised_reason", "")
               for fragment in ["C_001", "C_002", "x >= 6", "x + 2*y"])
test("Sanitised reason contains zero constraint internals", not has_leak)

# ------------------------------------------------------------------
# CLAIM 9 — OUTPUT CONTRACT COMPLIANCE
# ------------------------------------------------------------------
print("\n--- CLAIM 9: OUTPUT CONTRACT COMPLIANCE ---")
required_top = {"status", "violations", "decision_id", "output_id", "timestamp"}
required_violation = {"constraint_identity", "canonical_form", "actual_value", "expected"}
d_allow = gw8.check_output({"bindings": {"x": 6, "y": 5}, "output_id": "SCHEMA-ALLOW"})
d_block2 = gw8.check_output({"bindings": {"x": 4, "y": 3}, "output_id": "SCHEMA-BLOCK"})
for label, d in [("ALLOW", d_allow), ("BLOCK", d_block2)]:
    test(f"{label} decision has required top-level keys", set(d.keys()) == required_top)
    for v in d["violations"]:
        test(f"{label} violation entry has required keys", set(v.keys()) == required_violation)

print("\n" + "=" * 70)
print(f"RESULTS: {PASS} passed, {FAIL} failed")
if FAIL == 0:
    print("VERDICT: ALL CLAIMS VALIDATED — Phase 4 is externally proven.")
else:
    print(f"VERDICT: {FAIL} failure(s) — claims violated.")
print("=" * 70)
